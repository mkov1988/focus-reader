# Book covers are served same-origin from /covers by default:
#
#   npm run mirror:covers   # downloads + optimizes covers into public/covers/
#
# That folder is bundled into the build and runtime-cached by the service worker,
# so you don't need to set anything here. Only set VITE_COVER_BASE if you'd
# rather host the covers on a CDN (then upload public/covers/ contents there):
#
# Example (jsDelivr off a GitHub repo named focus-reader-covers):
# VITE_COVER_BASE=https://cdn.jsdelivr.net/gh/youruser/focus-reader-covers@v1
VITE_COVER_BASE=

# Book text works the same way. It's served same-origin from /books by default:
#
#   npm run mirror:books    # downloads + strips book text into public/books/
#
# Books open from there (or from the device cache) without touching gutenberg.
# Only set VITE_BOOK_BASE to host the text on a CDN instead (upload public/books/):
# VITE_BOOK_BASE=https://cdn.jsdelivr.net/gh/youruser/focus-reader-books@v1
VITE_BOOK_BASE=
